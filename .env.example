# Research Radar environment variables

# Copy this file to `.env` and fill in at least one LLM provider key.

# ---- Database ----
# Default: sqlite:///data/research_radar.db
# DATABASE_URL=sqlite:///data/research_radar.db

# ---- LLM Providers (configure at least one) ----

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1/responses
# OPENAI_MODEL_FAST=gpt-4o-mini
# OPENAI_MODEL_STANDARD=gpt-5.2
# OPENAI_MODEL_PREMIUM=gpt-5.4

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages
# ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
# ANTHROPIC_MODEL_STANDARD=claude-sonnet-4-6
# ANTHROPIC_MODEL_PREMIUM=claude-opus-4-6
